<footer class="footer">
  <div class="group">
  	<p>Built on <%= link_to "Rob Sterlini", "https://robsterlini.co.uk", title: "Visit Rob’s site", rel: "nofollow" %>’s Middleman boilerplate <%= link_to "the repository on GitHub", "https://github.com/robsterlini/middleplate", title: "Fork Middleplate on Github" %>.
    <% data.pages.pages.each do |nav| %>
      <% if nav.nav.footer != false %>
        <span>
          <a title="<%= nav.nav.alt %>" href="/<%= nav.slug %>"><%= nav.nav.label %></a>
        </span>
      <% end %>
    <% end %>
  </div>
</footer>